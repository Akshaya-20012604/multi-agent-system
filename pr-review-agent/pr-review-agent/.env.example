# GitHub credentials
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_secret_string_here

# Ollama settings (no API key needed — runs locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ChromaDB path (local folder, auto-created)
CHROMA_DB_PATH=./chroma_db

# SQLite path
SQLITE_DB_PATH=./pr_review.db

# Agent settings
AGENT_TIMEOUT_SECONDS=120
MIN_CONFIDENCE_SCORE=0.6
